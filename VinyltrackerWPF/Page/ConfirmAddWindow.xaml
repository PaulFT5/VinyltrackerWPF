<Window x:Class="VinyltrackerWPF.Page.ConfirmAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Add" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" Background="#FF2D2D30">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image x:Name="AlbumImage" Width="150" Height="150" Stretch="UniformToFill"/>
            <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="AlbumName" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Foreground="white"/>
                <TextBlock x:Name="ArtistName" FontSize="14" Foreground="Gray" Margin="0,5,0,0"/>
                <TextBlock x:Name="YearText" FontSize="14" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Add" Width="80" Height="30" Click="Add_Click"/>
        </StackPanel>
    </Grid>
</Window>