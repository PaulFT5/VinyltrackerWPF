<Window x:Class="VinyltrackerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vinyl Tracker" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--Top bar #FF2D2D30-->
        <Grid Grid.Row="0" Background="Black">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <!--Name-->
            <TextBlock Grid.Column="0" Text="Vinyl Tracker" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>

            <!--Search bar-->
            <Border Grid.Column="1" Height="35" Width="540" Background="Black" CornerRadius="18" VerticalAlignment="Center" Margin="20" BorderThickness="1" BorderBrush="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                   <!--Text icon-->
                    <TextBlock Grid.Column="0"
                   Text="🔍"
                   FontSize="14"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="Gray"/>

                    <!--Text bar-->
                    <TextBox x:Name="SearchBox" Grid.Column="1" 
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Left"
                             FontSize="14"
                             Foreground="LightGray"
                             Text="Search for albums or artists..."
                             GotFocus="SearchBox_GotFocus" 
                             LostFocus="SearchBox_LostFocus"
                             Padding="5,0"/>
                             
                </Grid>
            </Border>

            <Button Grid.Column="2" Content="Log out" Width="70" Height="30" VerticalAlignment="Center" Margin="0,0,20,0"/>
        </Grid>

        <!--Collection details/value-->
        <Grid Grid.Row="1" Background="#FF2D2D30">
            <Border BorderThickness="1" BorderBrush="white" CornerRadius="15" Margin="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Total Albums" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Collection price" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Favourite Genre" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="0" Grid.Row="1" x:Name="AlbumCount"  Text="{Binding AlbumCounter}" FontSize="18" Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" x:Name="CollectionValue" Text="{Binding CollectionValueAmount, StringFormat=€{0:F2}}" FontSize="18" Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding FavoriteGenre}" FontSize="18" Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!--Collection-->
        <Grid Grid.Row="2" Background="#FF2D2D30">
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding VinylCollection}">

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3E3E42" CornerRadius="10" Margin="15,10,15,10" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0" Source="{Binding ImageUrl}" Width="130" Height="130" 
                                   Stretch="UniformToFill" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Album}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="18" Foreground="#DDDDDD"/>
                                        <TextBlock Text="{Binding Year, StringFormat='Year: {0}'}" FontSize="14" Foreground="Gray" Margin="0,0,0,10"/>

                                        <TextBlock Text="Tracklist:" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>

                                        <ItemsControl ItemsSource="{Binding Tracks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Foreground="LightGray" FontSize="13" Margin="0,2,0,0">
                                                <Run Text="{Binding Position}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding Title}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding Duration}"/>
                                                <Run Text=")"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!--Add button-->
        <Grid Grid.Row="3" Background="#FF2D2D30">
            <Border Width="78" Height="35" Background="#FF2D2D30" CornerRadius="20" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0, 0, 20, 10" BorderThickness="1" BorderBrush="White">
                <Button x:Name="QuickAddBtn" Content="Add" Click="QuickAddBtn_Click" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" Cursor="Hand" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Grid>
</Window>
